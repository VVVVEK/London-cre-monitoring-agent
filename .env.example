# ============================================================================
# London Office CRE Monitoring AI Agent - .env.example
# ============================================================================
# How to use:
#   1) Copy this file to ".env"
#   2) Fill only the fields you need
#   3) Run: python -m app.main check-config
#
# Security:
#   - NEVER commit ".env"
#   - ".env.example" is safe to commit because it contains no secrets
#
# ----------------------------------------------------------------------------
# Quick setup profiles
# ----------------------------------------------------------------------------
# Profile A (no keys, fully offline/synthetic demo):
#   Leave all keys empty and keep PREFER_SAMPLE_DATA=false (or true)
#
# Profile B (recommended for interview demo: observed macro + observed news):
#   Set FRED_API_KEY and NEWSAPI_KEY
#
# Profile C (full experience: add LLM-assisted news tagging/Q&A):
#   Set OPENAI_API_KEY (OpenAI) OR use Qwen via OpenAI-compatible endpoint
# ----------------------------------------------------------------------------

# --- LLM: OpenAI OR Qwen (DashScope OpenAI-compatible mode) ---
# OpenAI example:
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_BASE_URL=
#
# Qwen example (replace above values):
# LLM_PROVIDER=qwen
# OPENAI_API_KEY=your_dashscope_key
# OPENAI_MODEL=qwen-turbo
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Macro data (FRED) ---
# Free API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- News data ---
# RSS works without key; NewsAPI is optional but recommended for richer coverage.
# NewsAPI key: https://newsapi.org/
NEWSAPI_KEY=
NEWSAPI_QUERY=London office OR "commercial real estate" London OR "Canary Wharf" office
# Multiple feeds can be separated by commas.
NEWS_RSS_FEEDS=https://www.bing.com/news/search?q=london+office+market&format=rss

# --- Runtime behavior ---
# true  = always use sample_data only (stable demo)
# false = try live sources first; fallback to sample_data when unavailable
PREFER_SAMPLE_DATA=false

# --- Local storage / freshness / logging ---
DB_PATH=cre_agent.db
STALENESS_DAYS_CRE=120
STALENESS_DAYS_MACRO=45
LOG_FILE=logs/cre_agent.log
